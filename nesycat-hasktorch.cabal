cabal-version: 2.4
name: nesycat-hasktorch
version: 0.1.0.0
synopsis: NeSyCat Framework with HaskTorch
description: Typed tensor category for the NeSyCat neurosymbolic framework
license: MIT
author: User
maintainer: user@example.com

library
  exposed-modules:
    A_Syntax.A_Categorical.CatVocab,
    A_Syntax.B_Typological.DATA_Vocab,
    A_Syntax.B_Typological.FDATA_Vocab,
    A_Syntax.B_Typological.TENS_Vocab,
    A_Syntax.C_Logical.TwoMonBLat,
    A_Syntax.C_Logical.A2MonBLat,
    A_Syntax.D_NonLogical.Dice_Vocab,
    A_Syntax.D_NonLogical.Crossing_Vocab,
    A_Syntax.D_NonLogical.Countable_Vocab,
    A_Syntax.D_NonLogical.Weather_Vocab,
    A_Syntax.D_NonLogical.MNIST_Vocab,
    A_Syntax.D_NonLogical.BinaryVocab,
    A_Syntax.E_Grammatical.Formulas,
    C_Semantics.A_Categorical.Monads.Dist,
    C_Semantics.A_Categorical.Monads.Giry,
    B_Interpretation.B_Typological.DATA,
    B_Interpretation.B_Typological.FDATA,
    B_Interpretation.B_Typological.TENS,
    B_Interpretation.C_Logical.Real,
    B_Interpretation.C_Logical.Boolean,
    B_Interpretation.C_Logical.Tensor,
    B_Interpretation.C_Logical.TensUniform,
    B_Interpretation.C_Logical.JitCompile,
    B_Interpretation.C_Logical.TensReal,
    B_Interpretation.C_Logical.Product,
    B_Interpretation.C_Logical.SProd,
    B_Interpretation.C_Logical.LTNp,
    B_Interpretation.C_Logical.Goedel,
    B_Interpretation.C_Logical.Lukasiewicz,
    B_Interpretation.D_NonLogical.Dice,
    B_Interpretation.D_NonLogical.Weather,
    B_Interpretation.D_NonLogical.Crossing,
    B_Interpretation.D_NonLogical.Countable,
    B_Interpretation.D_NonLogical.Supremum,
    B_Interpretation.D_NonLogical.MNIST,
    B_Interpretation.D_NonLogical.MNIST_MLP,
    B_Interpretation.D_NonLogical.BinaryUniform,
    B_Interpretation.D_NonLogical.BinaryUniformMLP,
    B_Interpretation.D_NonLogical.BinaryReal,
    B_Interpretation.D_NonLogical.BinaryRealMLP,
    MNIST_Loader,
    C_Semantics.A_Categorical.Monads.Expectation,
    C_Semantics.A_Categorical.Monads.Expectation_TENS,
    D_Inference.D_NonLogical.MNIST_Training,
    D_Inference.D_NonLogical.BinaryTrainingUniform,
    D_Inference.D_NonLogical.BinaryTrainingReal,
    D_Inference.D_NonLogical.BinaryTrainingUniformJIT,
    D_Inference.D_NonLogical.BinaryTrainingRealJIT,
    B_Interpretation.C_Logical.TensRealBeta,
    B_Interpretation.E_Grammatical.BinaryFormulasRealBeta,
    D_Inference.C_Logical.BetaTrainingReal,
    D_Inference.D_NonLogical.BinaryTrainingRealBeta,
    B_Interpretation.E_Grammatical.BinaryFormulasUniform,
    B_Interpretation.E_Grammatical.BinaryFormulasReal,
    E_Benchmark.Metrics.Metrics
  hs-source-dirs: ., B_Interpretation/D_NonLogical/data/mnist
  build-depends:
    base >=4.16,
    bytestring,
    containers,
    mtl,
    numeric-tools,
    hasktorch,
    statistics,
    time
  default-language: Haskell2010

executable nesycat-hasktorch
  main-is: Main.hs
  hs-source-dirs: B_Interpretation/E_Grammatical
  build-depends:
    base,
    nesycat-hasktorch,
    containers,
  default-language: Haskell2010

executable mnist-test
  main-is: MNISTMain.hs
  hs-source-dirs: B_Interpretation/E_Grammatical
  build-depends:
    base,
    nesycat-hasktorch,
    mtl,
    containers,
    hasktorch
  default-language: Haskell2010

executable binary-test
  main-is: BinaryMainUniform.hs
  hs-source-dirs: B_Interpretation/E_Grammatical
  ghc-options: -rtsopts
  build-depends:
    base,
    nesycat-hasktorch,
    mtl,
    containers,
    hasktorch
  default-language: Haskell2010

executable binary-test-jit
  main-is: BinaryMainUniformJIT.hs
  hs-source-dirs: B_Interpretation/E_Grammatical
  ghc-options: -rtsopts
  build-depends:
    base,
    nesycat-hasktorch,
    mtl,
    containers,
    hasktorch,
    time
  default-language: Haskell2010

executable binary-test-real
  main-is: BinaryMainReal.hs
  hs-source-dirs: B_Interpretation/E_Grammatical
  ghc-options: -rtsopts
  build-depends:
    base,
    nesycat-hasktorch,
    mtl,
    containers,
    hasktorch,
    time
  default-language: Haskell2010

executable binary-test-jit-real
  main-is: BinaryMainRealJIT.hs
  hs-source-dirs: B_Interpretation/E_Grammatical
  ghc-options: -rtsopts
  build-depends:
    base,
    nesycat-hasktorch,
    mtl,
    containers,
    hasktorch,
    time
  default-language: Haskell2010

executable binary-test-real-beta
  main-is: BinaryMainRealBeta.hs
  hs-source-dirs: .
  ghc-options: -rtsopts
  build-depends:
    base,
    nesycat-hasktorch,
    mtl,
    containers,
    hasktorch,
    time,
    statistics
  default-language: Haskell2010
